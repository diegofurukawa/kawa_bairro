# =============================================================================
# PORTAINER ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file and configure values in Portainer UI
# DO NOT commit actual .env file to Git
# =============================================================================

# -----------------------------------------------------------------------------
# NETWORK CONFIGURATION
# -----------------------------------------------------------------------------
# External Docker network name (must exist before deployment)
DOCKER_NETWORK_NAME=kawatech-network

# -----------------------------------------------------------------------------
# IP ADDRESS ALLOCATION
# -----------------------------------------------------------------------------
# Static IP addresses for services on the kawatech-network
IP_KAWA_MIGRATE=10.10.0.25
IP_KAWA_APP=10.10.0.30

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# External port mapping (host:container)
EXTERNAL_PORT=3313

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL connection parameters
POSTGRES_HOST=10.10.0.10
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=db_meubairro_jddasoliveiras
POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# DATABASE URL (constructed from above or override)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
