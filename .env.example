# =============================================================================
# PORTAINER ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Configure these values in Portainer UI.
# Do not commit actual .env files to Git.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# ===== PORTS =====
BACKEND_PORT=3225
FRONTEND_PORT=8291

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# DB_HOST: PostgreSQL container/service name or IP
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=furukawa_schedule
DB_USER=postgres
DB_PASSWORD=change-me-to-a-secure-password
DB_SCHEMA=public
DB_SSL=false

# Full connection string (auto-generated from components above)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}
