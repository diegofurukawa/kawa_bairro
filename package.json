    "db:import:safe": "node scripts/safe-import.js",
    "db:migrate": "node scripts/migrate-db.js",
    "db:deploy": "npm run db:generate && npm run db:push && npm run db:migrate",
    "db:deploy:prod": "node scripts/deploy-prod.js",
    "db:dev": "scripts\\dev-db.bat",
    "start:prod": "npm run db:deploy && yarn start",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
