generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quadra {
  quadra_id     Int       @id @default(autoincrement())
  quadra_name   String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cep           String?
  numero        String?
  endereco      String?
  complemento   String?
  bairro        String?
  cidade        String?
  estado        String?
  estado_codigo String?
  pais          String?
  pais_iso      String?
  unidades      Unidade[]

  @@map("quadra")
}

model Unidade {
  unidade_id     Int      @id @default(autoincrement())
  unidade_numero String   @unique
  quadra_id      Int
  mora           String?
  contato        String?
  vistoria       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  quadra         Quadra   @relation(fields: [quadra_id], references: [quadra_id], onDelete: Cascade)

  @@map("unidade")
}

enum AvisoTipo {
  Aviso
  Publi

  @@map("aviso_tipo")
}

model Aviso {
  aviso_id     Int       @id @default(autoincrement())
  titulo       String
  corpo        String
  url          String?
  url_metadata String?
  autor        String?
  ativo        Boolean   @default(true)
  fixado       Boolean   @default(false)
  tipo         AvisoTipo @default(Publi)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("aviso")
  @@index([ativo, fixado, createdAt])
}
