generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quadra {
  quadra_id     Int       @id @default(autoincrement())
  quadra_name   String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cep           String?
  numero        String?
  endereco      String?
  complemento   String?
  bairro        String?
  cidade        String?
  estado        String?
  estado_codigo String?
  pais          String?
  pais_iso      String?
  unidades      Unidade[]

  @@map("quadra")
}

model Unidade {
  unidade_id     Int      @id @default(autoincrement())
  unidade_numero String   @unique
  quadra_id      Int
  mora           String?
  contato        String?
  vistoria       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  quadra         Quadra   @relation(fields: [quadra_id], references: [quadra_id], onDelete: Cascade)

  @@map("unidade")
}

model Aviso {
  aviso_id     Int      @id @default(autoincrement())
  titulo       String   @db.VarChar(200)
  corpo        String   @db.Text
  url          String?  @db.VarChar(2048)
  url_metadata Json?
  autor        String?  @db.VarChar(100)
  ativo        Boolean  @default(true)
  fixado       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("aviso")
  @@index([ativo, fixado, createdAt])
}
