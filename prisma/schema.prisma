// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quadra {
  quadra_id   Int     @id @default(autoincrement())
  quadra_name String  @unique
  unidades    Unidade[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quadra")
}

model Unidade {
  unidade_id     Int      @id @default(autoincrement())
  unidade_numero String   @unique
  quadra_id      Int
  mora           String?  // JSON string para armazenar array de moradores
  contato        String?  // JSON string para armazenar array de contatos
  quadra         Quadra   @relation(fields: [quadra_id], references: [quadra_id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("unidade")
}
